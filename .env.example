# ResolveAI — Environment Variables

# Google Gemini API Key (get one at https://aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here

# LLM Provider: "gemini" (default). Architecture supports swapping to "openai" or "claude".
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-flash-latest

# PostgreSQL (used by Docker Compose)
# DATABASE_URL is set automatically by docker-compose via environment block
# For local dev outside Docker:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resolveai